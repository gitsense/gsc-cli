  },
  "editors": {
    "zed": "zed %s",
    "vscode": "code %s",
    "cursor": "cursor %s",
    "vim": "vim %s",
    "nvim": "nvim %s",
    "nano": "nano %s",
    "subl": "subl %s",
    "gedit": "gedit %s",
    "kate": "kate %s"
  },
  "terminals": {
    "gnome-terminal": "gnome-terminal --working-directory=\"%s\"",
    "konsole": "konsole --workdir \"%s\"",
    "xfce4-terminal": "xfce4-terminal --working-directory=\"%s\"",
    "alacritty": "alacritty --working-directory \"%s\"",
    "kitty": "kitty --directory \"%s\"",
    "xterm": "xterm -e 'cd \"%s\" && bash'",
    "gnome-terminal-ws": "gnome-terminal --working-directory=\"%s\" -- bash --rcfile \"${GSC_MAPPED_WS_ROOT}/.gsc-init.sh\"",
    "konsole-ws": "konsole --workdir \"%s\" -e bash --rcfile \"${GSC_MAPPED_WS_ROOT}/.gsc-init.sh\"",
    "xfce4-terminal-ws": "xfce4-terminal --working-directory=\"%s\" -e bash --rcfile \"${GSC_MAPPED_WS_ROOT}/.gsc-init.sh\"",
    "alacritty-ws": "alacritty --working-directory \"%s\" -e bash --rcfile \"${GSC_MAPPED_WS_ROOT}/.gsc-init.sh\"",
    "kitty-ws": "kitty --directory \"%s\" bash --rcfile \"${GSC_MAPPED_WS_ROOT}/.gsc-init.sh\"",
    "xterm-ws": "xterm -e 'cd \"%s\" && bash --rcfile \"${GSC_MAPPED_WS_ROOT}/.gsc-init.sh\"'"
  }
