    "version": "1.2.0",
    "description": "Updated workspace terminal aliases to use {{GSC_MAPPED_WS_ROOT}} placeholder for absolute path injection by the handler.",
    "language": "json",
    "created_at": "2026-03-06T14:42:00.000Z",
    "authors": "GLM-4.7 (v1.0.0), GLM-4.7 (v1.2.0)"
  },
  "editors": {
    "zed": "zed %s",
    "vscode": "code %s",
    "cursor": "cursor %s",
    "vim": "vim %s",
    "nvim": "nvim %s",
    "notepad": "notepad %s",
    "notepad++": "notepad++ %s"
  },
  "terminals": {
    "wt": "wt.exe -d \"%s\"",
    "cmd": "start cmd /K cd /d \"%s\"",
    "powershell": "start powershell -NoExit -Command \"Set-Location '%s'\"",
    "git-bash": "start \"\" \"%PROGRAMFILES%\\Git\\bin\\bash.exe\" --cd=\"%s\"",
    "wt-ws": "wt.exe -d \"%s\" powershell -NoExit -Command \". \\\"{{GSC_MAPPED_WS_ROOT}}/.gsc-init.ps1\\\"\"",
    "powershell-ws": "start powershell -NoExit -Command \"Set-Location '%s'; . \\\"{{GSC_MAPPED_WS_ROOT}}/.gsc-init.ps1\\\"\"",
    "git-bash-ws": "start \"\" \"%PROGRAMFILES%\\Git\\bin\\bash.exe\" --cd=\"%s\" --rcfile \\\"{{GSC_MAPPED_WS_ROOT}}/.gsc-init.sh\\\""
  }
}
