  "_gsc_meta": {
    "component": "Terminal and Editor Launch Templates",
    "block_uuid": "b4c5d6e7-f8a9-0b1c-2d3e-4f5a6b7c8d9e",
    "parent_uuid": "768f4737-55c6-4e59-9c52-9c9f8c6ea723",
    "version": "1.4.0",
    "description": "Updated workspace terminal commands to invoke 'gsc ws <hash>' instead of manually spawning a shell with an init script.",
    "language": "json",
    "created_at": "2026-03-06T14:42:00.000Z",
    "authors": "GLM-4.7 (v1.0.0), GLM-4.7 (v1.2.0), GLM-4.7 (v1.3.0), GLM-4.7 (v1.4.0)"
  },
  "editors": {
    "zed": "zed %s",
    "vscode": "code %s",
    "cursor": "cursor %s",
    "vim": "vim %s",
    "nvim": "nvim %s",
    "notepad": "notepad %s",
    "notepad++": "notepad++ %s"
  },
  "terminals": {
    "wt": "wt.exe -d \"%s\"",
    "cmd": "start cmd /K cd /d \"%s\"",
    "powershell": "start powershell -NoExit -Command \"Set-Location '%s'\"",
    "git-bash": "start \"\" \"%PROGRAMFILES%\\Git\\bin\\bash.exe\" --cd=\"%s\"",
    "wt-ws": "wt.exe -d \"%s\" gsc ws %s",
    "powershell-ws": "start powershell -NoExit -Command \"Set-Location '%s'; gsc ws %s\"",
    "git-bash-ws": "start \"\" \"%PROGRAMFILES%\\Git\\bin\\bash.exe\" --cd=\"%s\" -c \"gsc ws %s\""
  }
}
