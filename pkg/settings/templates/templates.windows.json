{
  "editors": {
    "zed": "zed %s",
    "vscode": "code %s",
    "cursor": "cursor %s",
    "vim": "vim %s",
    "nvim": "nvim %s",
    "notepad": "notepad %s",
    "notepad++": "notepad++ %s"
  },
  "terminals": {
    "wt": "wt.exe -d %s",
    "cmd": "start cmd /K \"cd /d %s\"",
    "powershell": "start powershell -NoExit -Command \"Set-Location '%s'\"",
    "git-bash": "start \"\" \"%PROGRAMFILES%\\Git\\bin\\bash.exe\" --cd=%s",
    "wt-ws": "wt.exe -d %s powershell -NoExit -Command \". .gsc-init.ps1\"",
    "powershell-ws": "start powershell -NoExit -Command \"Set-Location '%s'; . .gsc-init.ps1\"",
    "git-bash-ws": "start \"\" \"%PROGRAMFILES%\\Git\\bin\\bash.exe\" --cd=%s --rcfile .gsc-init.sh"
  }
}
